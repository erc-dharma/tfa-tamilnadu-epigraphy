    <text xml:space="preserve">
        <body>
            
            <div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:83215"><!--check script-->
                
                <ab>
                    <lb n="1"/><hi rend="grantha">svasti śrī</hi> <g ref="sym:doubleBar" type="punctuation">.</g>
                </ab>
                
                <p>
                    v<choice><orig>i</orig><reg>ī</reg></choice>ra-pā
                    <lb n="2" break="no"/>ṇṭiyaṉai-t talai koṇṭa
                    <lb n="3"/>kō-p-parakēcari-paṉmaṟki yā
                    <lb n="4" break="no"/>ṇṭu Aiñc-āvatu
                </p>
                
                <p>
                    palku<supplied reason="omitted">ṉ</supplied>ṟa
                    <lb n="5" break="no"/>-k-kōṭṭattu vacukūr-nāṭṭu
                    <lb n="6" break="no"/>-k kāma-p-pullūr <hi rend="grantha">sabhai</hi>yō
                    <lb n="7" break="no"/>⌉m tañcavūr periya Aṅkā
                    <lb n="8" break="no"/>ṭi viyāpāri māyilaṭṭi maka
                    <lb n="9" break="no"/>ṉ Aiyyā<unclear>ṟṟa</unclear>ṅkaḷ-ākiya
                    <lb n="10"/>nūṟṟeṇma-k-<seg rend="check">karava</seg><!--OR is it kavaṟa, as below?-->-ceṭ
                    <lb n="11" break="no"/>ṭikku Eṅkaḷūr per-ēri kiḻ
                    <lb n="12"/>yāṅkaḷ-uṭaiya <seg rend="check">caṅkaraccaṉ</seg><!--See cuṅkāccaṉ, line 24-->
                    <lb n="13"/>paṭṭiyil teṟk’ aṭaiya
                    <lb n="14"/>Ar<hi rend="grantha">ai</hi>ye Oru mā nilamu
                    <lb n="15" break="no"/>m vilai-<hi rend="grantha">dravya</hi>mum Iṟai
                    <lb n="16" break="no"/>-<hi rend="grantha">travya</hi>mum Aṟa-k-koṇṭu
                    <lb n="17"/><seg rend="check"><gap reason="illegible" quantity="4" unit="character"/></seg> ceytu kuṭu
                    <lb n="18" break="no"/>ttōm <hi rend="grantha">sabhai</hi>yōmum</p>
                <p>
                    <lb n="19"/>muṟ-colla-paṭṭa <seg rend="check"><g ref="sym:dash-double" type="punctuation">.</g></seg> māyila
                    <lb n="20" break="no"/>ṭṭi makaṉ Aiyyāṟa
                    <lb n="21" break="no"/>ṉ-ākiya nūṟṟeṇma-k-ka
                    <lb n="22" break="no"/>vaṟa-ceṭṭi-y-ēṉu<unclear>m ṇa</unclear>ḷi
                    <lb n="23"/><hi rend="grantha">sabhai</hi>yār pakkal vilai
                    <lb n="24" break="no"/>kku koṇṭa <seg rend="check">cuṅkāccaṉ</seg> pa
                    <lb n="25" break="no"/>ṭṭiyil teṟk’ aṭaiya Arai
                    <lb n="26" break="no"/>yē Oru mā nilamum <hi rend="grantha">śrī</hi>-kāmai
                    <lb n="27" break="no"/>-nakkar kōyilil nontā-vi
                    <lb n="28" break="no"/>ḷakku Oṉṟum <hi rend="grantha">ca</hi><seg rend="check">n</seg><hi rend="grantha">trādi</hi>ttaval
                    <lb n="29"/>Erippat’ āka Ivv-araiyē Oru <unclear>mā</unclear>
                    <lb n="30"/>nilamum ṇūtteṉ nūṟṟe
                    <lb n="31" break="no"/>ṉma-k-kavaṟa-ceṭṭi-y-ēṉ <hi rend="grantha">śrī</hi>-kō
                    <lb n="32" break="no"/>yil-uṭai<supplied reason="omitted">ya</supplied> <hi rend="grantha">śi</hi>va-<hi rend="grantha">brāhma</hi>ṇarō
                    <lb n="33" break="no"/>mum Ivv-ar<hi rend="grantha">ai</hi>yē Oru mā ni
                    <lb n="34" break="no"/>lamuṅ koṇṭu tivvikai<seg rend="check">co</seg>
                    <lb n="35" break="no"/>ṉṟum <hi rend="grantha">cantrādi</hi>ttaval nontā
                    <lb n="36" break="no"/>-viḷakku Erippōm ānōm civa-<hi rend="grantha">brā</hi>
                    <lb n="37" break="no"/><hi rend="grantha">hma</hi>ṇarōm <hi rend="grantha">sabhai</hi>yōmum
                </p>
                <p>
                    Iṉni
                    <lb n="38" break="no"/>lañ cuṭṭi n<choice><sic>i</sic><corr>i</corr></choice>rvilai koḷḷa
                    <lb n="39" break="no"/>ppi<seg rend="check">rā</seg>tōm āṉōm <hi rend="grantha">sabhai</hi>yōm
                </p>
                
                <p>
                    I
                    <lb n="40" break="no"/><unclear>tu</unclear> <hi rend="grantha">rakṣikkum</hi> <gap reason="lost" quantity="5" unit="character"/>
                </p>
                
            </div>
            
