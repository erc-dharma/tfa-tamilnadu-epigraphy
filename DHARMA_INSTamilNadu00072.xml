		<lb n="8" break="no"/>ttu <gap reason="lost" quantity="11" unit="character"/> kiḻamaiyum
		<lb n="9"/>peṟṟa<gap reason="lost" quantity="10" unit="character"/> tu nāḷ vaṭa
