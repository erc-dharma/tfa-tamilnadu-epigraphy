            <div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">
                <ab>
                    <lb n="1"/><hi rend="grantha">svasti śrī</hi>
                </ab>
                <p>
                    <hi rend="grantha">pūrvva-d<supplied reason="lost">e</supplied><unclear>śa</unclear></hi>mum <hi rend="grantha"><unclear>gaṃgai</unclear></hi>yum kaṭāramum koṇṭ-aruḷiṉa <gap reason="lost" quantity="12" unit="character"/>
                    <lb n="2"/>yār <hi rend="grantha">śrī</hi>-rā<hi rend="grantha">jendra</hi>-cōḻa-devaṟku yāṇṭu <num value="20">2 10+</num> vatu <hi rend="grantha">ja</hi><supplied reason="omitted">ya</supplied>ṅkoṇṭa-cōḻa-maṇṭalattu E <gap reason="lost" quantity="2" unit="character"/> kōṭṭattu
                    <lb n="3"/>nakaraṅ kāñcipurattu ma nakarattu nikarili cōḻak kacci <gap reason="lost" quantity="2" unit="character"/>
                    <lb n="4"/><hi rend="grantha">brāhma</hi>ṇaṉ <hi rend="grantha">śrī</hi>-muṭittalūr kiḻavaṉ nārā <gap reason="lost" quantity="2" unit="character"/> vittaṉu
                    <lb n="5"/>m Ikkuṭip pēruḻāṉ kramavittaṉu <gap reason="lost" quantity="3" unit="character"/> rā <gap reason="lost" quantity="3" unit="character"/> pa
                    <lb n="6"/>perun teruvil viyāpāri paḻaiyāṟu kiḻāṉ
                    <lb n="7"/>keruḷaṉ Attiyūr <gap reason="lost" quantity="1" unit="character"/> Arumoḻi tēvap <gap reason="lost" quantity="1" unit="character"/>
                    <lb n="8"/>parun teruvil viyāpāri kumpiṭuvāṇa <gap reason="lost" quantity="2" unit="character"/> ḷ vaṭikaḷ cī rāmaṉu
                    <lb n="9" break="no"/>m Aḻakiya cōḻa-p-perun-teruvil viyāpāri Āṭava <gap reason="lost" quantity="1" unit="character"/> lāṉ mākāḷaṉu
                    <lb n="10" break="no"/>m nitta vinōta-p-perun-teruvil viyāpāri nārāyaṇaṉ kūttāṭiyum kāḻi
                    <lb n="11"/>kula tilaka-p-perun-teruvil cāliyaṉ viṭaṅkaṉ Ēṟaṉum cōḻa-cūṭāmaṇi-p-perun
                    <lb n="12" break="no"/>-teruvil tāḻiyaṉ vīraṭṭaṉ ciṅka-k koḻuntaṉum Ivvaṉaivōm tiru-vekkā
                    <lb n="13"/>vaṇai-k kiṭant-aruḷiṉa parama-svāmikku Iṟaiyili tēvatāṉa māka nāṅkaḷ
                    <lb n="14"/>kuṭutta tuṇi nilattukku-k kīḻ-pāṟk’ ellai rājēndra-cōḻaṉ <gap reason="lost" quantity="5" unit="character"/>
                    <lb n="15"/>m teṉ-pāṟk’ ellai Ivv-āḻvār tiru-nōkkil varukiṟa cippi paṟṟukku vaṭakku
                    <lb n="16"/>m mēl-pāṟk’ ellai pañcavaṉ-mātēvi-vatikku-k kiḻakkum vaṭa-pāṟk’ellai paṉṉākī
                    <lb n="17"/><hi rend="grantha">śva</hi>ram-uṭaiyār tītta-k kuḷattiṉ teṉ-karai-p paṟṟi-k kiḻakku nōkki-p pōkiṟa vati
                    <lb n="18" break="no"/>kku teṟkum In-nāṟ-pāṟk’ ellaikku Uṭpaṭṭa Uḷnilam Oḻiviṉṟi viṟṟu Ivv-āḻ
                    <lb n="19" break="no"/>vār <hi rend="grantha">śrī</hi>-paṇṭārattu kācu kallāl kaikkoṇṭa poṉ nūṟṟu Iru-patt’ añcu
                    <lb n="20" break="no"/>m kaikkoṇṭu viṟṟu-k kuṭuttōm tiru-vekkā vaṇaik kiṭant-aruḷiṉa parama-svāmi
                    <lb n="21" break="no"/>kku Ivv-aṉaivōm In-nilattu mēl ṉōkkiṉa maramum kīḻ nōkkiṉa kiṇaṟum maṉai
                    <lb n="22" break="no"/>yum maṉai-p-paṭappu maṟṟum Eppēṟpaṭṭatum Uḷ nilam Oḻiviṉṟi Ivv-āḻvā
                    <lb n="23" break="no"/>rku tiru-nantavaṉam-āka Ittuṇi nilam Iṟaiyili tēvatāṉam-āka Emmil-icai
                    <lb n="24" break="no"/>nta poruḷ aṟa-k kaikkoṇṭu viṟṟu-k kuṭuttōm Ituvē poruḷ mā
                    <lb n="25"/>vaṟuti-p poruṭ cela-Ōlai Āvat’āka Iru-kāl-āvatu mu-k-kāl-āvatum vilai ya
                    <lb n="26" break="no"/>ṟṟuk kuṭuttōm tiru vekkā vaṇaik kiṭan taruḷiya svāmikaḷukku
                    <lb n="27"/><hi rend="grantha">śrī</hi>-kāñci-mā-nakarattu Ivvaṉaivōmm-āṉa krāma paṇikka Eḻutiṉēṉ nakkaṉ <gap reason="lost" quantity="2" unit="character"/>
                    <lb n="28" break="no"/>kku vi<hi rend="grantha">ṣṇu</hi> malaiyāṉ māṉakaraṅ kulōttamaṉ-ēṉ Ivai Eṉṉ eḻuttu <gap reason="lost" quantity="1" unit="character"/>
                </p>
