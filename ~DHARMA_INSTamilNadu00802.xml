            <div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">
                <ab>
                    <lb n="1"/><hi rend="grantha">svasti śrī</hi>
                </ab>
                <p>
                    <hi rend="grantha">pūrvva-d<supplied reason="lost">e</supplied><unclear>śa</unclear></hi>mum gaṅgaiyum kaṭāramum koṇṭ-aruḷiṉa <gap reason="lost" quantity="11" unit="character"/>
                    <lb n="2"/>yār <hi rend="grantha">śrī</hi>-rā<hi rend="grantha">jendra</hi>-cōḻa-devaṟku yāṇṭu 20 vatu ja<unclear>ya</unclear>ṅkoṇṭa-cōḻa-maṇṭalattu E <gap reason="lost" quantity="4" unit="character"/> kōṭṭattu
                    <lb n="3"/>nakaraṅ kāñcipurattu ma nakarattu nikarili cōḻak kacci <gap reason="lost" quantity="2" unit="character"/>
                    <lb n="4"/>rāhmaṇaṉ śrī-muṭittalūr kiḻavaṉ nārā <gap reason="lost" quantity="2" unit="character"/> vittaṉu
                    <lb n="5"/>m Ikkuṭip pēruḻāṉ krama vittaṉu <gap reason="lost" quantity="3" unit="character"/> rā <gap reason="lost" quantity="3" unit="character"/> pa
                    <lb n="6"/>perun teruvil viyāpāri paḻaiyāṟu kiḻāṉ
                    <lb n="7"/>keruḷaṉ Attiyūr <gap reason="lost" quantity="1" unit="character"/> Arumoḻi tēvap <gap reason="lost" quantity="1" unit="character"/>
                    <lb n="8"/>parun teruvil viyāpāri kumpiṭuvāṇa <gap reason="lost" quantity="2" unit="character"/> ḷ vaṭikaḷ cī rāmaṉu
                    <lb n="9"/>m Aḻakiya cōḻap perun teruvil viyāpāri Āṭava <gap reason="lost" quantity="1" unit="character"/> lāṉ mākāḷaṉu
                    <lb n="10"/>m nitta vinōtap perunteruvil viyāpāri nārāyaṇaṉ kūttāṭiyum kāḻi
                    <lb n="11"/>kula tilakap perun teruvil cāliyaṉ viṭaṅkaṉ Ēṟaṉum cōḻa cūṭāmaṇip perun
                    <lb n="12"/>teruvil tāḻiyaṉ vīraṭṭaṉ ciṅkak koḻuntaṉum Iv vaṉaivōm tiru vekkā
                    <lb n="13"/>vaṇaik kiṭan taruḷiṉa parama svāmikku Iṟaiyili tēvatāṉa māka nāṅkaḷ
                    <lb n="14"/>kuṭutta tuṇi nilattukku-k kīḻpāṟk’ ellai rājēndra-cōḻaṉ <gap reason="lost" quantity="5" unit="character"/>
                    <lb n="15"/>m teṉpāṟkallai Iv vāḻvār tiru nōkkil varukiṟa cippi paṟṟukku vaṭakku
                    <lb n="16"/>m mēl pāṟ kellai pañcavaṉ mātēvi vatikkuk kiḻakkum vaṭa pāṟ kellai paṉṉākī
                    <lb n="17"/>śvara muṭaiyār tīttak kuḷattiṉ teṉ karaip paṟṟik kiḻakku nōkkip pōkiṟa vatikku teṟkum In nāṟpāṟ kellaikku Uṭpaṭṭa Uḷnilam Oḻi viṉṟi viṟṟu Iv vāḻ
                    <lb n="18"/>vār śrī paṇṭārattu kācu kallāl kaikkoṇṭa poṉ nūṟṟu Irupattañcu
                    <lb n="19"/>m kaikkoṇṭu viṟṟuk kuṭuttōm tiru vekkā vaṇaik kiṭan taruḷiṉa paramasvāmi
                    <lb n="20"/>kku Iv vaṉaivōm In nilattu mēl ṉōkkiṉa maramum kīḻ nōkkiṉa kiṇaṟum maṉai
                    <lb n="21"/>yum maṉaip paṭappu maṟṟum Eppēṟ paṭṭatum Uḷ nilam Oḻiviṉṟi Iv vāḻvā
                    <lb n="22"/>rku tiru nanta vaṉa māka It tuṇi nilam Iṟaiyili tēvatāṉa māka Emmi licai
                    <lb n="23"/>nta poruḷaṟak kaikkoṇṭu viṟṟuk kuṭuttōm Ituvē poruḷ mā
                    <lb n="24"/>vaṟutip poruṭ cela Ōlai Āvatāka Iru kālāvatu mukkā lāvatum vilai ya
                    <lb n="25"/>ṟṟuk kuṭuttōm tiru vekkā vaṇaik kiṭan taruḷiya svāmikaḷukku
                    <lb n="26"/>śrī kāñci mānakarattu Iv vaṉaivōmmāṉa krāma paṇikka Eḻutiṉēṉ nakkaṉ <gap reason="lost" quantity="2" unit="character"/>
                    <lb n="27"/>kku viṣṇu malaiyāṉ māṉakaraṅ kulōttama ṉēṉ Ivai Eṉ ṉeḻuttu <gap reason="lost" quantity="1" unit="character"/>
                </p>
