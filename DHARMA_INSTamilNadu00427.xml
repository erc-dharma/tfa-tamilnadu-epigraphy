<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:83215">
			
	<ab>		
		<lb n="1"/><hi rend="grantha">s<supplied reason="lost">vasti śrī</supplied></hi>
	</ab>
	<p>
		<gap reason="lost" quantity="4" unit="character" precision="low"/> c-ca <gap reason="lost" quantity="3" unit="character" precision="low"/>
		<lb n="2" break="no"/>ra-va<reg>r</reg>tti kōṉēri <gap reason="lost" quantity="8" unit="character" precision="low"/>
		<lb n="3" break="no"/>ṉ Uṭaiyār tiru-k-koṭuṅ-ku
		<lb n="4" break="no"/>ṉṟam-uṭaiya ṉāyaṉār-kōyil
		<lb n="5"/>tāṉattārkku Ik-kōyil mā
		<lb n="6" break="no"/>ṭāpattiyam tiru-malai Uṭaiyā
		<lb n="7" break="no"/>ṉum tiru-mañcaṉam Uṭaiyāṉum
		<lb n="8"/>kāṇi-y-āy varuva-c ceytu pō
		<lb n="9" break="no"/>tukiṟa paṭiyālē Irupatt' eṭṭā
		<lb n="10" break="no"/>vatu mutal Ivarkaḷukku cantirā
		<lb n="11" break="no"/>titta-vaṟ cellum paṭi ka(l)lilum
		<lb n="12"/>cempilum veṭṭi-k koḷ
		<lb n="13" break="no"/>vat' āka-c coṉṉōm
	</p>
	<p>
		Ip-paṭik
		<lb n="14" break="no"/>ku kallilum cempilum ve(ṭ)
		<lb n="15" break="no"/>ṭi-k kuṭukka Ivai caṟukampūr uṭai
		<lb n="16" break="no"/>yāṉ Eḻuttu <g ref="sym:tam-pillaiyarCuli" type="punctuation">.</g>		
	</p>
	<p>
		
		yāṇṭu 28-vatu
		<lb n="17"/>nāḷ 220 Ivai vāṇātarāyaṉ E
		<lb n="18" break="no"/>ḻuttu <g ref="sym:tam-pillaiyarCuli" type="punctuation">.</g>
		
	</p>
