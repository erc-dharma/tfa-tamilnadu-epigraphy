            <div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">
                <ab>
                    <lb n="1"/><hi rend="grantha"><supplied reason="lost">śu</supplied>bham astu</hi>
                </ab>
                <p>
                    cittiṟa-pāṉu-varu<hi rend="grantha">ṣaM</hi> kāṟtikai-mā<hi rend="grantha">sa</hi>m <num value="12"><g type="numeral">10</g> 2</num>
                    <lb n="2"/>U<hi rend="grantha">ddhā</hi>ṉa tuvāteciyil
                </p>
                
                <p>
                    <hi rend="grantha">śrīma</hi>te <hi rend="grantha">rāmā</hi>ṉu<hi rend="grantha">jā</hi>ya na<hi rend="grantha">maḥ</hi>
                </p>
                
                <p>                    
                    <lb n="3"/><hi rend="grantha">śrīmad-veda</hi>-māṟka <hi rend="grantha">pra</hi>ti<hi rend="grantha">ṣṭhāpa</hi>nācār<unclear cert="low">i</unclear>ya U<hi rend="grantha">bha</hi>ya-ve<hi rend="grantha">dā</hi>n
                    <lb n="4" break="no"/>tācāriya<hi rend="grantha">r-ā</hi>na periya tirumalai nampi tiru-va<hi rend="grantha">ṃ</hi>sattu <hi rend="grantha">śa</hi>
                    <lb n="5" break="no"/><seg rend="check"><hi rend="grantha">ṭha</hi>-<unclear>ma</unclear></seg>ru<hi rend="grantha">ṣa</hi>ṇa-<hi rend="grantha">gotra</hi>ttu Āpa<hi rend="grantha">staMpa-sūtra</hi>ttu <gap reason="lost" quantity="4" unit="character"/>
                    <lb n="6"/><seg rend="check">ye<!--EF: khe?--></seg> <gap reason="lost" quantity="10" unit="character" precision="low"/> vayyaṅkār kumārar ye
                    <lb n="7" break="no"/>ṭṭūr tirumalai kumāra tāttācāriyar Ayyaṉ
                    <lb n="8" break="no"/>ṉāṉā-<hi rend="grantha">kotra</hi>ttu <hi rend="grantha">śrī</hi>-vayi<hi rend="grantha">ṣṇa</hi>varkaḷukkum tā<seg rend="check">ṉā <hi rend="grantha">dha</hi></seg>
                    <lb n="9"/><seg rend="check"><hi rend="grantha">rma</hi></seg>m-āka <gap reason="lost" quantity="10" unit="character" precision="low"/> <hi rend="grantha">M</hi> paṇṇi-k kuṭutta paṭi <gap reason="lost" quantity="4" unit="character" precision="low"/>
                    <lb n="10"/>muṉṉāḷ coṉṉa vaṇṇa<hi rend="grantha">M</hi> ceyta perumāḷ <hi rend="grantha">sa</hi>ṉṉati                    
                    <lb n="11"/>tiru-v<choice><orig>i</orig><reg>ī</reg></choice>ti Akkiṟāram-āka y-ik-kōyil <hi rend="grantha">śrī</hi>-paṇṭārattār <hi rend="grantha">sta</hi>lattu-p pēr
                    <lb n="12"/>kaiyyil Upa<hi rend="grantha">kṣe</hi>ya-taṟma-<hi rend="grantha">śāsa</hi>ṉam paṇṇi kuṭu<seg rend="check">tta maṉai</seg> muppattu
                    <lb n="13"/>m<choice><orig>u</orig><reg>ū</reg></choice>ṉṟu tiru-māḷikai maṉaiyum cunta<choice><sic><hi rend="check">rara</hi></sic><corr>rā</corr></choice>c<add place="below">ā</add>r<unclear cert="low">i</unclear>yar puram Eṉṟu
                    <lb n="14"/>y-inta tiru-vītikku-t tiru-ṉāmam cātti y-inta tiru-vīti A
                    <lb n="15" break="no"/><hi rend="grantha">grahāra</hi>ttukku Āka vāraṇavāci Eṉkuṟa <hi rend="check">grā</hi>mattai
                    <lb n="16"/>coṉṉa vaṇṇam ce<supplied reason="omitted">y</supplied>ta perumāḷukku <gap reason="illegible" quantity="8" unit="character" precision="low"/>
                    <lb n="17"/><gap reason="lost" quantity="2" unit="character" precision="low"/> kālattil nāḷ oṉṟukku kalanē Añcu kuṟuṇi Amutu-paṭi
                    <lb n="18" break="no"/>yum patiṉ ēḻu taḷikai-y-āka O<hi rend="grantha">ru</hi> Ava<hi rend="grantha">saraM Ā</hi>ka Amutu c<choice><orig>e</orig><reg>ey</reg></choice>t-a
                    <lb n="19" break="no"/>ruḷa-p paṇṇi y-inta-p patiṉ Eḻu taḷikai <hi rend="grantha">prasāda</hi>mum tiru
                    <lb n="20" break="no"/>-māḷikai Oṉṟukku tiṉam ṉāṉāḻi <hi rend="grantha">prasādam</hi> Eṭuttu ko
                    <lb n="21" break="no"/>ṇṭu <hi rend="grantha">Ācandrā<unclear cert="low">r</unclear>kkam-āka</hi> paṟṟi Aṉupavittu-k koḷḷa-k kaṭa
                    <lb n="22" break="no"/>varkaḷḷ ākavum
                </p>
                <p>
                    Aṉupavikku<choice><orig>mm</orig><reg>m</reg></choice> iṭattu y-inta muppattu
                    <lb n="23"/>mūṉṟu maṉaikkum varum <hi rend="grantha">samudā</hi>ya-<hi rend="grantha">prāpti</hi>yum Uḷ
                    <lb n="24" break="no"/>paṭa ni<hi rend="grantha">dhi</hi>-ni<hi rend="grantha">kṣepa-jala-pāṣā</hi>ṇa-<hi rend="grantha">Akṣiṇy-<choice><sic>o</sic><corr>ā</corr></choice>gāmi-sā</hi>
                    <lb n="25"/><hi rend="grantha">ā<unclear>ddhya</unclear>M</hi> Eṉkuṟa <hi rend="grantha">Aṣṭa-bhoga</hi>-tē<hi rend="grantha">ja-svāmi</hi>
                    <lb n="26"/><unclear>yaṅkaḷum</unclear> <gap reason="lost" quantity="4" unit="character" precision="low"/> Uḷpaṭa <hi rend="grantha">dhā</hi>ṉā<hi rend="grantha">dhi</hi> vinimaya
                    <lb n="27"/>vikkiṟaiyaṅ<hi rend="grantha">ka</hi>ḷukkum yō<hi rend="grantha">ga</hi><choice><orig>mm</orig><reg>m</reg></choice>-āka puṉya <hi rend="grantha">pramā</hi>
                    <lb n="28" break="no"/>-nirape<hi rend="grantha">kṣamm-ā</hi>ka <hi rend="grantha">Ā</hi> <gap reason="illegible" quantity="12" unit="character" precision="low"/>
                    <lb n="29"/><hi rend="grantha">cā</hi>r<unclear cert="low">i</unclear>yamm-āka <gap reason="illegible" quantity="12" unit="character" precision="low"/>
                    <lb n="30" break="no"/>kavum
                </p>
                <p>
                    y-ippaṭi cammatit=tu tārā-<hi rend="grantha">pūrvva-dharmma-śāsa</hi><supplied reason="omitted">na</supplied><hi rend="grantha">M</hi>
                    
                    <lb n="31"/>paṇṇi-k kuṭuttōm ṉāṉā-kōtrattu śrī-vayiṣṇavarkaḷukku
                    <lb n="32" break="no"/>m tāttācāryar Ayyaṉēṉ Inta <hi rend="grantha">su</hi>n=tarācāryar <hi rend="grantha">pura</hi>m ti
                    <lb n="33" break="no"/>ru-māḷikaiyil kuṭiyirukkiṟa śrī-vaiṣṇavarkaḷukku pēr viparam
                    <lb n="34"/>vaṭa ciṟaku ti mutal mūṉṟu maṉaiyum ṉālā maṉaiyum tāttā
                    <lb n="35" break="no"/>cāryar Ayyaṉ y-ic-ciṟaku kiḻakku mutal maṉaiyum 2 Āmaṉai
                    <lb n="36" break="no"/>yum Ayyaṉ śrī-rā<unclear>ma</unclear> śrī-Ayyaṉ teṉ-ciṟaku kiḻak
                    <lb n="37" break="no"/>ku mutal maṉai malai kuṉiya niṉṟa perumāḷ Iṇā 2 ā maṉai kiṭāmpi
