                    <lb n="5" break="no"/>t=til vant-iraṅkiyiruk=kum pōtu kuppalna
                    <lb n="6" break="no"/>ttam veṅkiṭṭi nāk=kaṉ pātakāṇikkai
                    <lb n="7"/><g type="paṇam"/> <num value="30">3 <g type="numeral">10</g></num> <g type="poṉ"/> poṉṉum <num value="400">4 <g type="numeral">100</g></num> Arici kāyka
                    <lb n="8" break="no"/>ri ney-pāl-uṭaṉē koṇṭu vantu ṟācā
                    <lb n="9" break="no"/>vai-k= kaṇṭāṉ ṟācāvukku cantōcam-āki ni <seg rend="check"><gap reason="illegible" quantity="1" unit="character"/></seg>
                    <lb n="10" break="no"/>ku Emi kāvelē yek=kaṭavu vittivi Eṉa
                    <lb n="11"/>kēṭṭāṟ veṅkiṭṭi nāk=kaṉ coṉṉatu
                    <lb n="12"/>nēṉu Uṇṭē kiṟāmāṉiki cātiṉappaṭṭa
                    
                    <lb n="13" break="no"/>yāṉiki tēvaruvāḷu Uttaṟavu kāvelē
                    <lb n="14"/>y-eṉṟu kēṭṭāṉ Antappaṭik=ku ṟācāUtta
                    <lb n="15" break="no"/>rāv' āccutu
                    
                    <list>
                        <item>yitark=ku māl cempaṟaṇi El
                            <lb n="16" break="no"/>laik=ki teṟk=ku</item>
                        <item>
                            cēṭapaṭṭik= kiṟāmat=tukku kiḷak=ku</item>
                        <item>
                            vī
                            <lb n="17" break="no"/>ṟāḷampaṭṭi māluk=ku vaṭak=ku</item>
                        <item>
                            pūcāntirak= kiṟāma
                            <lb n="18" break="no"/>ttuk=ku mēṟk=ku</item>
                    </list>
                    
                    y-inta nāṅk' el<choice><orig>k</orig><reg>l</reg></choice>aik=k' uḷppa
                    <lb n="19" break="no"/>ṭṭa kirāmam kuppalnat=tat=tuk=ku nāṭṭāmai pi
                    <lb n="20" break="no"/>ñcai māṉipam Ūruk=ku teṟk=ku 5 caṅkili ni
                    <lb n="21" break="no"/>lam nañcai māṉipam <g type="mēṟpaṭi"/> kirāmat=tuk=k' uḷp
                    <lb n="22" break="no"/>paṟavil naṭuvāk=kālukku vaṭak=ku 4 kāṇi Āka
                    <lb n="23"/>y-ivaḷavum nāṭṭāmai mutamai veṅkiṭṭi
                    <lb n="24"/>ṉāk=kaṉuk=ku contam-āka E<unclear reason="eccentric_ductus">ḻ</unclear>uti-k kuṭut=ta tām
                    <lb n="25" break="no"/>pura-cātiṉappaṭṭayam
                </p>
                <p>
                    y-itarkku cācci mati
                    <lb n="26" break="no"/>ppaṉūr cūṟappaṉāk=kaṉ cēṭapaṭṭi perum
                    <lb n="27" break="no"/>āḷuṉāk=kaṉ pūcāntiṟam ciṉṉa-māya-t-tē
                    <lb n="28" break="no"/>vaṉ
                </p>
                <p>
                    y-itai yātām orutaṟ aṭi Aḷit=tā
                    <lb n="29" break="no"/>l mīṉācci cokkaliṅkar kēḷppāṟ
                </p>
                <p>                
                    <lb n="30"/>y-inta-p paṭṭayañ ceytavaṉ matuṟā-puri ⌈
                    <lb n="31" break="no"/>mēla-vācal caṇmukam Ācāri y-inta-p paṭi
