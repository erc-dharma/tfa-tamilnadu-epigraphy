        <body>
            
            
            
            <div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:83215">
                <ab xml:lang="san-Latn" rendition="class:grantha maturity:83215">
                    <lb n="1"/><g ref="sym:tam-pillaiyarCuli" type="symbol">@</g> <hi rend="grantha"><unclear>svasti śrī</unclear></hi>
                </ab>
                
                <p>
                    tirupuvaṉa-c-cakkara-vattikaḷ <hi rend="grantha">śrī</hi>-cuntara-pāṇṭiya-tēvaṟkku yāṇṭu <g type="numeral">10</g> Āvatu kēyya-māṇikka-vaḷaṉāṭṭu vaṭakāl
                    <lb n="2"/>parivaṭṭa nakaram pukalōkattu Uṭaiyār pañcavaṉ mā<hi rend="grantha">de</hi>vi<hi rend="grantha">śvara</hi>m-uṭaiyār kōyilukku tiru-vātavū<supplied reason="omitted">r</supplied>-nāyaṉārai Ēṟi-Aruḷa paṇṇiṉa ṉākai-y-āṉa ⌈
                    <lb n="3" break="no"/>cōḻa-ku<supplied reason="omitted">lava</supplied>lli-paṭ=ṭiṉattu tiru-p-paḷḷi-p-pāṟ<choice><sic>t</sic><corr>ṟ</corr></choice>u ṉāyakattāril Āṇṭāṉ kōtayāṉa kulōttuṅka-rāyaṉ-ēṉ Iṉ-ṉāyaṉāṟkku Amutu-paṭikkum t<choice><sic>a</sic><corr>i</corr></choice>ruviḷakku
                    <lb n="4" break="no"/>m nāyanā<del>ṉā</del><add place="overstrike">ṟ</add><choice><sic>t</sic><corr>k</corr></choice>ku koṇṭa<surplus>ṭa</surplus><add place="below">kantaṉ uṭaiyā<choice><orig>n</orig><reg>ṉ</reg></choice></add> nilamum nattamum Āvatu
                </p>
                
                <p>
                    I<hi rend="grantha">vū</hi>r piṭākai cankuṇaveḷi paṇappāṟṟukku vaṭakku taṭi <seg rend="check">mūṉṟu</seg> viṭṭuma
                    <lb n="5" break="no"/>ṟkku Amutu-paṭikkum tiruvi<!--incomplete?-->
                    <lb n="6"/>Ōṭai Eṉṟu pēr kūvappaṭṭa nila<supplied reason="subaudible">m</supplied> mā mu<supplied reason="omitted">m</supplied>māvaraiyum kaṇapati vāykkālukku mēṟkku puṟaṅkarampaṉāṭṭu vēḷāṉ maṉaikku valivala-nāṭu vēḷāṉ maṉai Iru
                    <lb n="7" break="no"/>ppu<seg rend="check">kku</seg>m 1/10 <g ref="sym:tam-nilam"/> m
                </p>
                
                <p>
                    I-nila<supplied reason="subaudible">m</supplied> mā mu<supplied reason="omitted">m</supplied>māvaraiyum Iṉ-nāyanāṟku Amutu-paṭikkum tiru-viḷakkum <hi rend="grantha">can<choice><orig>t</orig><reg>d</reg></choice>rādi<unclear>tya</unclear></hi>varai cella-k kaṭavat’ āka-k koṇṭu Iṭṭēṉ Āṇṭāṉ kō
                    <lb n="8" break="no"/>taiyāṉa kulōttuṅka-rāyaṉ-ēṉ
                </p>
                
                <p>                    
                    <list>
                        <item>Ik-kōyil <seg rend="check"><hi rend="grantha">A</hi></seg>kāraṇam<!--kāraṇavaṉ = accountant--> tiruvārūr ammāṉ Eḻuttu <g ref="sym:dashPlain" type="punctuation">.</g></item>
                        <item>Ik-kōyil tēvakammi piram<choice><orig>i</orig><reg>ī</reg></choice><hi rend="grantha">śvara</hi>-paṭṭaṉ Eḻuttu</item>
                        <item><lb n="9"/>Ik-kōyil kaṇakkaṉ paṉaṅk-uṭaiyāṉ v<choice><orig>i</orig><reg>ī</reg></choice>tiviṭaṅka-p perumāṉ Eḻu<supplied reason="omitted">ttu</supplied></item>
                    </list>
                    
                </p>
                
                
