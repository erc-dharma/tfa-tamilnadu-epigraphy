            <div resp="part:emfr" type="translation">
                
                <p n="1">
                    Prosperity! Fortune! 
                </p>
                
                <p n="1-3">
                    He who had this dance hall <supplied reason="lost">built</supplied>
                    is Vāṇarāyatēvar <hi rend="italic">alias</hi> the Lord of Tirunelvēli.	
