        <body>
            
            <div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">
                <ab>
                    <lb n="1"/><hi rend="grantha">svasti śrī</hi>
                </ab>
                <p>
                    matirai koṇṭa kō-p-parakē<hi rend="grantha">sa</hi>ri-paṉmaṟku yāṇṭu <num value="37">3 <g type="numeral">10</g> 7</num> Āvatu
                </p>
                <p>
                    Eyiṟ-kōṭṭattu Eyil-nāṭṭu-k ka
                    <lb n="2" break="no"/>ṇṇa-maṅkalattu Ūrōm Ivv-ūr muṭittalai kiḻavaṉ māṇikka-<hi rend="grantha">śa<unclear>r</unclear>mma</hi>ṉum Attaṇaṅ kiḻavaṉ kana<unclear>ka</unclear>c<unclear>e</unclear><hi rend="grantha">kha</hi>ra
                    <lb n="3" break="no"/>-<hi rend="grantha">śarmma</hi>ṉum muṭittalai kiḻavaṉ paṭṭa-<hi rend="grantha">śa<unclear>r</unclear>mma</hi>
                    <lb n="4" break="no"/>ṉum Ik-kuṭi-t tirumalaṅ kiḻavaṉ nārāya
                    <lb n="5" break="no"/>ṇa-<hi rend="grantha">bha</hi>ṭṭaṉum Ik-kuṭi-k kampa-<hi rend="grantha">śarmma</hi>ṉum Ik-kuṭi nārā
                    <lb n="6" break="no"/>yaṇa-<hi rend="grantha">bha</hi>ṭṭaṉum vayaluḻāṉ Aṅkāṭi-<hi rend="grantha">śarmma</hi>ṉum kaḷattu
                    <lb n="7" break="no"/>ḻāṉ nīlaka<hi rend="grantha">ṇṭha-śarmma</hi>ṉum Ivvaṉaivōm Eṅkaḷ pūmi-y-āṉa kaṇṇa-maṅ                    
                    <lb n="8" break="no"/>kalam nila-vilai-y-āvaṇa-k kai<choice><orig>-E</orig><reg>y-e</reg></choice>ḻuttu kacci-p-pēṭṭu-t tiru-vekkā-v-a
                    <lb n="9" break="no"/>ṇai-k kiṭant-aruḷiṉa Aṉanta-nārāyaṇa-parama-<hi rend="grantha">svāmi</hi>kku viṟṟu-k kuṭukkiṟa nilam 
                    <list>
                        <item>kīḻ-pāṟ
                            <lb n="10" break="no"/>k’ ellai tiru-v-attiyūr Ellaikku mēṟku vekkā-v-āṟu tuṭaṅki vaṭakku nōkki-p pōki
                            <lb n="11" break="no"/>ṟa vatikku mēṟkum</item>
                        <item>teṉ-pāṟk’ ellai vekkā-v-āṟṟukku vaṭakkum</item>
                        <item>mēl-pāṟk’ el
                            <lb n="12" break="no"/>lai patt<choice><unclear>a</unclear><unclear>i</unclear></choice>ṉa-p pāṭi Ellaikku kiḻakkum</item>
                        <item>vaṭa-pāṟk’ ellai karumpuḻāṉ viḷākattu
                            <lb n="13"/>muṭittalai kiḻavaṉ Uṭaiya paḷḷi-p-paṭṭiyi n<choice><orig>i</orig><reg>ī</reg></choice>r pāyuṅ kālukku-t teṟkum</item>
                    </list>
                    tiru-v-attiyū
                    <lb n="14" break="no"/>r Ellaiyuḷ Eṅkaḷ kaṇṇa-maṅkala-t-tēttamāṉa k<choice><orig>i</orig><reg>ī</reg></choice>ḻai-Araiyum mēlai-y-araiyum
                    <lb n="15"/>Uṭpaṭṭa Iṉ-ṉāṟ-pāṟk’ ellai-y-uḷḷum Uḷ-nilam oḻiv’ iṉṟi Oṭump’ ōṭi Āmai nakuntatum kuḷamum koṭ
                    <lb n="16" break="no"/>ṭakāramum n<choice><orig>i</orig><reg>ī</reg></choice>r-nilamum kollaiyum maṉaiyum maṉai-p-paṭappaiyum kaṉṟu-mēy-kaḻaniyum n<choice><orig>i</orig><reg>ī</reg></choice>r pōṉa vā
                    <lb n="17" break="no"/>ykkālum mēṉōkkiya maramu<unclear>m</unclear> kīṇōkkiya kiṇaṟu<supplied reason="subaudible">m</supplied> mīṉ-paṭu paḷḷamum tēṉ-paṭu pottamu-<unclear>k</unclear>-kā
                    <lb n="18" break="no"/>ṭum Uṭpaṭa Eppērpaṭṭa nilam Uḷ-nilam Oḻiv’ iṉṟi viṟṟu Emmil icainta poṉ kācu kalaṉ <gap reason="illegible" quantity="3" unit="character"/>
                    <lb n="19"/>muṉṉūṟṟ’ aṟupatt’ eḻu kaḻañcum kiḻi y-aṟa-k kai-k-koṇṭu tiru-vekkā-v-aṇai-k kiṭant-aruḷiṉa Ananta-nār
                    <lb n="20" break="no"/>āyaṇa-p-parama-<hi rend="grantha">svāmi</hi>kku viṟṟu-k kuṭuttōm kaṇṇa-maṅkalattu Ūravarōm
                </p>
                <p>
                    Eṅkaḷ karumpuḻāṉ vi
                    <lb n="21" break="no"/>ḷākattukku n<choice><orig>i</orig><reg>ī</reg></choice>r pānta kāl kaṇṇa-maṅkalattukku mēl n<choice><orig>i</orig><reg>ī</reg></choice>r muṟaimai y-āvat’ āka Ip-paric’ oṭṭi Emmil icai
                    <lb n="22" break="no"/>nta poruḷ <num value="367">3 <g type="numeral">100</g> 6 <g type="numeral">10</g> 7</num> kaḻañcum kai-k-koṇṭu tiru-vekkā-v-aṇai-k kiṭant-aruḷiṉa Aṉanta<surplus>nta</surplus>-nārāyaṇa-parama
                    <lb n="23" break="no"/><space type="defect"/>-<hi rend="grantha">svāmi</hi>kku viṟṟu-k kuṭuttōm kaṇṇa-maṅkalatt’ ūrōm
                </p>
                <p>
                    Ituvē poruḷ māvaṟuti-p poruṭ celav-ōlai y-ā
                    <lb n="24" break="no"/>vat’ ākavum
                </p>
                <p>Iru-kāl-āvatu mu-k-kāl-āvatum Emmil icainta poṉ ki<unclear>ḻ</unclear>i maṟa-k kai-k-koṇṭu tiru-vekk<surplus>i</surplus>ā-v-aṇai
                    <lb n="25" break="no"/>-k kiṭant-aruḷiṉa parama-<hi rend="grantha">svāmi</hi>kku v<unclear>i</unclear>ṟṟu-k kuṭuttōm kaṇṇa-maṅkalattu Ūrōm
                </p>
                <p>
                    Ivarkaḷ paṇiyāl nila
                    <lb n="26" break="no"/>-vilai-y-āvaṇam Eḻutiṉēṉ kaṇṇa-maṅkalam-uṭaiyāṉ Aruḷāḷaṉ pērāyiram-uṭaiyāṉ-ēṉ
                </p>
                <p>
                    Ivai
                    <lb n="27"/>Eṉ Eḻuttu <g type="punctuation" ref="sym:dashLong">.</g>
                </p>
            </div>
            
