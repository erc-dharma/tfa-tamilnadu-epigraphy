                    <lb n="8" break="no"/>vi<hi rend="grantha">ṣṇu-sthā</hi>ṉattil tiru-veḻkā nayiṉār kōyil <hi rend="grantha">śrī</hi>-paṇṭā
                    <lb n="9" break="no"/>rattārum <hi rend="grantha">śrī</hi>-kāriyam ceyyum vēta-māṟka-<hi rend="grantha">pra</hi>ti<hi rend="grantha">ṣṭā</hi>paṉācāriya U<hi rend="grantha">bha</hi>
                    <lb n="10" break="no"/>ya vētāntācāriyar-āṉa Eṭ<unclear>ṭūr</unclear> tirumalai-k kumāra tāttācāriyar
                    <lb n="11"/>Ayyaṉ <hi rend="grantha">sa</hi>ṉṉati Aḻak<supplied reason="lost">i</supplied>ya <unclear>ciṅkarum</unclear> <gap reason="lost" quantity="4" unit="character"/> <hi rend="grantha"><choice><orig>k</orig><reg>g</reg></choice>otra</hi>ttu A
                    <lb n="12" break="no"/><hi rend="grantha">pastaMbha-sūtra</hi>ttu <seg rend="check"><unclear>E</unclear>suśśra gobha</seg>yar-āṉa tirumalai nampi tiruvaṅ
                    <lb n="13" break="no"/>ki<hi rend="grantha">sa</hi>ttu Ayyā vaiyyaṅkār kumārar tāttā<hi rend="grantha"><choice><sic>ś</sic><corr>c</corr></choice></hi>āriyar Ayya
                    <lb n="14" break="no"/><choice><orig>n</orig><reg>ṉ</reg></choice> Avarkaḷukku Upa<hi rend="grantha">kṣa</hi>ya-ta<unclear>ṟ</unclear><hi rend="grantha">ma-śāsa</hi>ṉa<hi rend="grantha">m</hi> paṇṇi-k kuṭutta paṭi                    
                    <lb n="15"/>y-ivv<!--EF: Ivv?-->-emperumāṉ <hi rend="grantha">sa</hi>ṉṉati tiruv<choice><orig>i</orig><reg>ī</reg></choice>ti kōpurattukku mē
                    <lb n="16" break="no"/>ṟku Āla Aṭi maṇṭapattukku kiḻak<unclear>ku</unclear> <gap reason="lost" quantity="1" unit="character"/> ṉa <unclear cert="low">ciṟa</unclear>ku maṉai <num value="19"><unclear cert="low"><g type="numeral">10</g> 9</unclear></num>
                    <lb n="17"/>vaṭa ciṟaku maṉai <num value="17"><g type="numeral">10</g> 7</num> tiruv<choice><orig>i</orig><reg>ī</reg></choice>ti Uḷ taḷi 8 Aṭi <num value="60">6 <g type="numeral">10</g></num>
                    <lb n="18"/>maṉai 1 k=ku Aṭi <num value="32">3 <g type="numeral">10</g> 2</num> vāl vīccu Aṭi <num value="120"><g type="numeral">100</g> 2 <g type="numeral">10</g></num> Āka ma
                    <lb n="19"/><num value="34">3 <g type="numeral">10</g> 4</num> k=ku y-inta pi<add place="below">ra</add>māṇattillē kaṇṭa catuccira
                    <lb n="20" break="no"/>maikkum U<hi rend="grantha">pakṣa</hi>yam-āka niṟcayitta <num value="90">9 <g type="numeral">10</g></num> mūliya
                    <lb n="21"/><hi rend="grantha">M</hi> <seg rend="check">pu<!--EF: a symbol?--></seg> <num value="600">6 <g type="numeral">100</g></num> <gap reason="illegible" quantity="10" unit="character" precision="low"/> kkum y-inta maṉai
                    <lb n="22"/>muppattu ṉālum <hi rend="grantha">putra-pautra-pāramparā</hi>
                    <lb n="23"/>ya<hi rend="grantha">mm-ā</hi>ka <hi rend="grantha">Ācandrā</hi> <gap reason="lost" quantity="3" unit="character"/> āyiyāka U<hi rend="grantha">pakṣa</hi>ya-<hi rend="grantha"><unclear>dharmma</unclear></hi>
