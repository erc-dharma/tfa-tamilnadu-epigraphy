                </ab>
                <p>
                    <hi rend="grantha">śrī</hi>man ma<hi rend="grantha">hā</hi>-maṇṭalēcura yirā
                    <lb n="2" break="no"/><hi rend="grantha">jādhirāja-rāja</hi> pa<hi rend="grantha">rameśvara śrī</hi>
                    -vī<hi rend="grantha">ra-pra</hi>tāpa <hi rend="grantha">śrī</hi>-vī<hi rend="grantha">ra śrī-raṅga-deva mahā</hi>
                    <lb n="3" break="no"/>-rāyar <hi rend="grantha">prati</hi>vi-rā<hi rend="grantha">jya</hi><supplied reason="omitted"><hi rend="grantha">M</hi></supplied> paṇ=ṇi Aruḷā niṉṟa <hi rend="grantha">śā</hi>livā<hi rend="grantha">ha</hi>na-<hi rend="grantha">śa</hi>
                    kā<hi rend="grantha">ptaM</hi> 1000 5 100 4 kku mē                    
                    <lb n="4" break="no"/>l cellā niṉṟa <hi rend="grantha">citra-bhānu</hi>-<hi rend="grantha">saṃ</hi>va<hi rend="grantha">Tsara</hi>t=tu <hi rend="grantha">siṃha</hi>-nāyat=tu <hi rend="grantha">pūrvva-pakṣa</hi>
                    <lb n="5" break="no"/>t=tu pūca-na<hi rend="grantha">kṣatramuM tvā</hi>teciyum peṟṟa caṉi-vārattu nāḷ 
                </p>
                <p>
                    ceya
                    <lb n="6" break="no"/><hi rend="grantha">M</hi>-koṇṭa-cōḻa-maṇṭalattu <seg rend="check"><hi rend="grantha">ca</hi>ndrakiri</seg>-rā<hi rend="grantha">jya</hi>ttu Ū <gap reason="lost" quantity="5" unit="character"/>
