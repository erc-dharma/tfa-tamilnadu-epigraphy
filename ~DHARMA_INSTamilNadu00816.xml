                    <lb n="36" break="no"/>m paṇṇi-k kuṭuttōm tāttā<hi rend="grantha">cā</hi>riya Ayya<choice><orig>n</orig><reg>ṉ</reg></choice>
                    <lb n="37"/>Avarkaḷukku tiru-vekā-nayiṉār kōyil <hi rend="grantha">śrī</hi>
                    <lb n="38" break="no"/>-paṇṭārattārum <hi rend="grantha">śrī</hi>-kāriya<hi rend="grantha">m</hi> ceyyum Aḻakiya ciri
                    <lb n="39"/>ṅkart= tammōm
                </p>
                
                <p>
                    <list>
                        <item> I<hi rend="grantha">mā</hi>ni na<hi rend="grantha">rasiṃhasyākṣarā</hi>ṇa tāṉ
                            <lb n="40"/>vaḷar tuyilamantā<choice><orig>n</orig><reg>ṉ</reg></choice> paṭṭar co<choice><orig>nn</orig><reg>ṉṉ</reg></choice>a vaṇṇam <gap reason="lost" quantity="1" unit="character"/> ḷḷi paṭṭar Eḻu
                            <lb n="41" break="no"/>ttu</item>
                        <item>tiru-c-cittiṟa-kūṭa-p-paṭṭar co<choice><orig>nn</orig><reg>ṉṉ</reg></choice>a vaṇṇam <gap reason="lost" quantity="6" unit="character"/>
                            <lb n="42" break="no"/>ttu</item>
                        <item>kaṅka <gap reason="lost" quantity="4" unit="character"/> paṭṭar Aṇṇappa nayiṉār Eḻuttu</item>
                        <item><lb n="43"/>tā<hi rend="grantha">sa</hi><choice><orig>n</orig><reg>ṉ</reg></choice> m<unclear cert="low">ā</unclear> nampi Appaya mutali Uḷḷiṭṭār Eḻu
                            <lb n="44" break="no"/>ttu</item></list>
                </p>
                <p>
                    y-ippaṭikku y-inta <hi rend="grantha">śāsa</hi>ṉam Eḻutiṉamaik=ku
                    <lb n="45"/>kōyil kaṇakku poykai-nallūr Uṭai
                    <lb n="46" break="no"/>yār <seg rend="check"><gap reason="lost" quantity="2" unit="character"/> varata</seg> timayyā rāca<choice><orig>n</orig><reg>ṉ</reg></choice> Eḻuttu <g type="pc">.</g>
                </p>
                
