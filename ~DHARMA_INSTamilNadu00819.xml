            <div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">
                <ab>
                    <lb n="1"/><hi rend="grantha">śubham astu svasti</hi>
                </ab>
                <p>
                    <hi rend="grantha">śrīma</hi>n ma<hi rend="grantha">hā</hi>-maṇṭale<hi rend="grantha">śvara rājādirāja rāja</hi>- parame<hi rend="grantha">śvara śrī</hi>-vī<hi rend="grantha">ra-pra</hi>tāpa <hi rend="grantha">śrī-raṃga-de</hi>va-<hi rend="grantha">mahārā</hi>yar cū-<hi rend="grantha">siṃhāsa</hi>ṉattu vīṟṟ-iruntu <hi rend="grantha">pra</hi>tivī-<hi rend="grantha">rājyaM</hi> paṇṇi-Aruḷā niṉṟa
                    <lb n="2"/><hi rend="grantha">śā</hi>livākaṉa cakāṟputam <num value="156"><g type="numeral">1000</g> 5 <g type="numeral">100</g> 6</num> k=ku mēl cellā niṉṟa ta<hi rend="grantha">rā</hi>ṇi-<hi rend="grantha">saṃ</hi>va<hi rend="grantha">Tsara</hi>ttu <hi rend="grantha">siṃha</hi>-ṉāyaṟṟu pūṟva-<hi rend="grantha">pakṣa</hi>ttu catuṟteciyum cōma-vāramum peṟṟa Aviṭṭa-<hi rend="grantha">nakṣa</hi>trattu nāḷ
                </p>
                <p>
                    <hi rend="grantha">śrīmaT</hi>
                    <!--line 3 not clearly legible on the photos-->
                    <lb n="3"/>vēta māṟka pratiṣṭāpaṉācāriya Upaiya vētāntācāriya rāṉa Eṭṭūr tirumalai kumāra tātācārya Ayyaṉ cannatiyil <hi rend="grantha">pra</hi>tē <hi rend="grantha">gotra</hi>ttu Āpastampa-<hi rend="grantha">sūtra</hi>ttu ye<hi rend="grantha">jā</hi>kōpara tātācāriyar-āṉa kulacēkaran tirumalai nampi nān
                    <lb n="4"/><hi rend="grantha">śrī-raṃga-de</hi>va-<hi rend="grantha">mahārā</hi>yar kaiyilē <hi rend="grantha">pra</hi>ti-<hi rend="grantha">śrīhi</hi>taca-<hi rend="grantha">grāmaM ja</hi>ya<unclear>ṉ</unclear>-koṇṭa-cōḻa-maṇṭalattu ca<hi rend="grantha">n<choice><orig>t</orig><reg>d</reg></choice>ragiri-rājya</hi>ttu ceṅk<unclear>ā</unclear>ṭṭu kōṭṭattu kōṉāti-nāṭṭu tīttam pākkattu cīmaiyil <hi rend="grantha"><unclear>śā</unclear></hi>la-maṅkalaṅ kumpañ cērikku <hi rend="grantha">pra</hi>ti-ṉāmamāṉa
                    <lb n="5" break="no"/><hi rend="grantha">su</hi>n<unclear>ta</unclear>rā<hi rend="grantha">cā</hi>riya<seg rend="check"><unclear>pu</unclear><!--ra *--></seg><hi rend="grantha">ram</hi> tiruveḻkā vaṇai-k kiṭant-aruḷiya Aṉanta-nā<hi rend="grantha">rā</hi>yaṇa-<hi rend="grantha">pa</hi>ra<hi rend="grantha">masvāmi sa</hi>n=natiyil va<hi rend="grantha">ra</hi>kōṭi vimāṉa-c cayyil nittiya <hi rend="grantha">vāsa</hi>m paṇṇukiṟa ṉāṉā-kō<hi rend="grantha">tra</hi>ttu <hi rend="grantha">śrī</hi>-vayiṣṇavarkaḷukku <hi rend="grantha"><unclear>sama</unclear></hi>perumāṉ Inta cālai-maṅkalam kumpa
                    <lb n="6"/>ñ-cēri <hi rend="grantha">ga</hi>ṇacaṅ <gap reason="lost" quantity="1" unit="character"/> yil niccayitta paṅku <num value="64">6 <g type="numeral">10</g> 4</num></p>
                <p>
                    Inta paṅku Aṟu-pattu ṉālu kai koṇṭu <gap reason="lost" quantity="2" unit="character"/> kulacēkara-t tirumala nampi ṉālat toṉṟukku paṅkum <gap reason="lost" quantity="1" unit="character"/> nīkka paṅku nāṟpattu Eṭṭukku <gap reason="illegible" quantity="8" unit="character"/> kku paṅku <gap reason="illegible" quantity="8" unit="character"/> tiru-veḻkā nayiṉā
                    <lb n="7"/><gap reason="illegible"/><!--read on photos--> Eppērpaṭṭa <hi rend="grantha">sa</hi>kala-<hi rend="grantha">sa</hi>mutāya-<hi rend="grantha">prā</hi>ttiyum niti-ni<hi rend="grantha">kṣe</hi>pa-<hi rend="grantha"><unclear>ja</unclear></hi>la-pā<hi rend="grantha">ṣā</hi>ṇa Aka <gap reason="lost" quantity="2" unit="character"/> kāmiya <gap reason="lost" quantity="1" unit="character"/> tta <hi rend="grantha">sā</hi>ttiya Aṭṭa-pōkamum pu<hi rend="grantha">tra</hi> pau<hi rend="grantha">tra</hi> <seg rend="check">pāra <gap reason="lost" quantity="4" unit="character"/> yāka Aṉupavittu tirumala nampi nālat toṉṟukku</seg>
                    <lb n="8"/>naṭakka kaṭavat’ ākavum                    
                </p>
