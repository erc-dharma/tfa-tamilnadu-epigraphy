        <body>
            
            <div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">
                
                <div type="textpart" n="A"><head>First fragment</head>                    
                    <p>                        
                        <lb n="1"/><gap reason="lost" extent="unknown" unit="character"/> Iraṭṭa-pāṭi Ēḻ-arai Ilakkamu<supplied reason="lost">ṅ</supplied> koṇṭu pērāṟṟaṅkarai-k koppattu Ākava-mallaṉai Añcuvittavaṉ Āṉaiyuṅ kutiraiyum peṇṭir paṇṭāramuṅ koṇṭu vi<hi rend="grantha">jai</hi>ya-A<hi rend="grantha">bhiṣe</hi>kam paṇṇi vīra-ciṅkācaṉattu vīṟṟirunt-aruḷiṉa kō-p-parakēcari-panma <gap reason="lost" quantity="7" unit="character"/> yāṇṭu 7 Āvatu kāṭuveṭṭikaḷ nīlaṉ tāṅkiyār mummaṭi-cōḻa-tēva <gap reason="lost" quantity="4" unit="character"/> yār kuṭitāṅki janakiyārāṉa mātēviyār tiru-vekkā Āḻvārkku ce <gap reason="lost" quantity="7" unit="character"/> vitt-aruḷiṉa tiru-p pa <gap reason="lost" quantity="4" unit="character"/> taitta poṟ pū <gap reason="lost" quantity="3" unit="character"/>
                        <lb n="2"/><gap reason="lost" extent="unknown" unit="character"/> vaṭa kuṭiñaṟ kal ru poṟkācu <gap reason="lost" quantity="9" unit="character"/> Itil <gap reason="lost" quantity="3" unit="character"/> kuṟikkum muttuk <gap reason="lost" quantity="3" unit="character"/> <num value="67">6 <g type="numeral">10</g> 7</num> ñce <g type="tam-nilam"/> <g type="numeral">100</g> ṅ <gap reason="lost" quantity="3" unit="character"/> ṟakkum 13 <gap reason="lost" quantity="3" unit="character"/> nay <gap reason="lost" quantity="3" unit="character"/> kkum <gap reason="lost" quantity="4" unit="character"/> kuṭiñaṟ kal 3 kaṇṭa vaṇi poṟ <gap reason="lost" quantity="3" unit="character"/>
                        <lb n="3"/><gap reason="lost" quantity="1" unit="line"/>
                    </p>                    
                </div>
                
                <div type="textpart" n="B"><head>Second fragment</head>                    
                    <p>
                        <lb n="1"/><gap reason="lost" extent="unknown" unit="character"/> mūvēnta-vēḷārum Iraṭṭa-pāṭi-koṇṭa-cōḻa-mūvēnta-vēḷārum vikrama-cōḻa-mūvēnta-vēḷārum vīra-rājēndra-tamiḻatarayarum cōḻa-p <gap reason="lost" quantity="3" unit="character"/>
                        <lb n="2"/><gap reason="lost" extent="unknown" unit="character"/> laivan mūvēnta-vēḷārum vi<hi rend="grantha">je</hi>ya-rā<hi rend="grantha">jendra</hi>-mūvēnta-vēḷārum maṇṇai-koṇṭa-cōḻa-p-pallavatarayarum vikkirama-cōḻa-mūvēnta-vēḷārum <hi rend="grantha">rāja</hi>-ciṅka-<hi rend="grantha">brah</hi>mārāyarum nitta-vinōta-mūvēnta-vēḷāru <gap reason="lost" quantity="3" unit="character"/> nta-viḻupparayanum Aḻakiya cōḻa-mūvēnta-vē <gap reason="lost" quantity="7" unit="character"/>
                        <lb n="3"/><gap reason="lost" extent="unknown" unit="character"/> <hi rend="grantha">ndra</hi>-cōḻa-mūvēntavēḷārum <gap reason="lost" quantity="1" unit="character"/> navan Uttama <gap reason="lost" quantity="5" unit="character"/> rai kiḻān Ari-kula-viḻupparai <gap reason="lost" quantity="4" unit="character"/> pāṇṭiya-mūvēn=ta-vēḷārum parākkira <gap reason="lost" quantity="3" unit="character"/> vēn=ta-vēḷāru <gap reason="lost" quantity="3" unit="character"/> lacey <gap reason="lost" quantity="3" unit="character"/> m pañcavan <hi rend="grantha">brah</hi>mārāyaru <gap reason="lost" quantity="2" unit="character"/> cōḻa-kula <gap reason="lost" quantity="3" unit="character"/>
                    </p>
                </div>
                
                <div type="textpart" n="C"><head>Third fragment</head>
                    <p>
                        <lb n="1"/><gap reason="lost" extent="unknown" unit="character"/> vēḷānum puravu-vari<space type="unclassified"/>-tiṇai-k-kaḷattu <gap reason="lost" quantity="15" unit="character"/> muṭi-koṇṭa-cōḻa-p-pallavarayanum perum pēr-uṭaiyāṉ <gap reason="lost" quantity="4" unit="character"/>
                        <lb n="2"/><gap reason="lost" extent="unknown" unit="character"/> <unclear cert="low">pañca</unclear>vaṉ m<choice><orig>u</orig><reg>ū</reg></choice>vēn=tavē <gap reason="illegible" quantity="10" unit="character"/> <gap reason="lost" quantity="15" unit="character"/> <gap reason="illegible" quantity="20" unit="character"/>
                    </p>
                </div>
                
