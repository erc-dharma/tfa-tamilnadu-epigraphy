        <body>
            
            <div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">
                <ab>
                    <lb n="1"/><hi rend="grantha">svasti śrī</hi>
                </ab>
                <p>
                    tripuvaṉa-c-cak<hi rend="grantha">ra</hi>-vatti <expan><abbr>ku</abbr><ex>lōttuṅka</ex></expan>-cōḻa-tēvarkku yā<unclear>ṇ</unclear>ṭu 6 vatu mēca-nāyaṟṟu pūrva<!--EF: possibly Grantha, not visible on photos-->-pa<hi rend="grantha">kṣa</hi>ttu <gap reason="lost" quantity="10" unit="character"/> peṟṟa <gap reason="lost" quantity="5" unit="character"/>
                </p>
                <p>
                    jayaṅ-koṇṭa-cōḻa
                    <lb n="2" break="no"/>-maṇṭalattu <hi rend="grantha">śrī</hi>-kāñcipurattu Ananta-nārāyaṇa-<hi rend="grantha">svā</hi>mikku cēraṉai venṟa cōḻa kumāra<choice><orig>n</orig><reg>ṉ</reg></choice>u<supplied reason="subaudible">m</supplied> mānaṅ kāttān <seg rend="check">Amu</seg> taṭuvārōm <gap reason="illegible" quantity="3" unit="character"/> tu taṟai
                    <lb n="3"/><gap reason="illegible" quantity="6" unit="character"/> Inta cuvāmi tiru-maṭai-viḷākam tiru-nāmattu-k-kāṇi cannatikku vaṭakku <gap reason="lost" quantity="2" unit="character"/> tta mēl vāṭai kīḻ <gap reason="lost" quantity="3" unit="character"/> taikaḷum
                    
                    <lb n="4"/>ṉaiya <gap reason="lost" quantity="4" unit="character"/> teṟku mutal vaṭakkun teṟku <gap reason="lost" quantity="3" unit="character"/> tiru-k-kāṇi-y-āka-t tiru-k-kaiyālē tarukayil Inta <hi rend="grantha">de</hi>varkku tiruvaparaṇam <seg rend="check"><gap reason="lost" quantity="3" unit="character"/> tayum</seg><!--EF:curupinpum--> naṭat
                    <lb n="5"/>ta namakku vilai <gap reason="lost" quantity="4" unit="character"/> cantiyum <seg rend="check"><gap reason="illegible" extent="unknown" unit="character"/><!--more to read on photos--></seg>
                    <lb n="6"/>veṭṭi kuṭuttōm Itai <seg rend="check"><gap reason="illegible" extent="unknown" unit="character"/><!--more to read on photos--></seg>
                </p>
            </div>
            
