                <p>        
                    <hi rend="grantha">samasta-jagadādhāra <unclear>soma</unclear>-kula</hi>-ti<hi rend="grantha">laka madhurā-puri-mādha</hi>va <hi rend="grantha">keraḷa</hi>-va<hi rend="grantha">ṃśa</hi>-ni<hi rend="grantha"><unclear>r</unclear>mmū</hi>
                    <lb n="2" break="no"/><hi rend="grantha">la</hi>na <hi rend="grantha">laṃkā-<supplied reason="lost">dvī</supplied>paluṇṭha</hi>na <hi rend="grantha">dv<unclear>ī</unclear></hi>tiya-<hi rend="grantha">rāma coḷa-kula śaila-kul<unclear>ī</unclear>śa ka<unclear>r</unclear>ṇṇāṭa-rāja</hi>-vi<hi rend="grantha">drā</hi>vaṇa<hi rend="grantha"> kāṭaka-karikū<choice><sic>ṭh</sic><corr>ṭ</corr></choice>aṃ pākala</hi>
                    <lb n="3"/>vivi<hi rend="grantha">dha-ri<unclear>pu</unclear>-durgga-ma<unclear>r</unclear>dda</hi>na vī<hi rend="grantha">ra-kaṇṭha gopāla</hi>-<supplied reason="lost">vi</supplied><hi rend="grantha">pula-dā</hi>va<hi rend="grantha">daha</hi>na<hi rend="grantha"> kāñcīpura</hi>-va<hi rend="grantha">rādhīśvara ga</hi>ṇa<hi rend="grantha">pa</hi>ti-<hi rend="grantha">hari</hi>ṇa-<hi rend="grantha">śārdūla</hi>
                    <lb n="4"/>ne<hi rend="grantha">llūra-p<unclear>ura</unclear></hi> vi<hi rend="grantha">raci</hi>ta-vī<hi rend="grantha">rābhiṣeka pra</hi>ṇata-<hi rend="grantha"><unclear>rāja-pra</unclear></hi>ti<hi rend="grantha">ṣṭhāpaka mahārājādhirāja parame<unclear>śva</unclear>ra</hi> kōccaṭapaṉma
                    <lb n="5" break="no"/><unclear>r-āṉa</unclear> <hi rend="grantha">tribhu</hi>vaṉa-<hi rend="grantha">ścakra</hi>vat=ti<hi rend="grantha">ka</hi>ḷ <hi rend="grantha">śrī</hi>-sundara-pāṇṭiya-tēvaṟk=ku yāṇ<unclear>ṭu</unclear> <num value="15"><g type="numeral">10</g> 5</num> Āvatu
                </p>
                <p>
                    puraṭṭ<unclear>ā</unclear>t<supplied reason="lost">i</supplied>-mātattu <hi rend="grantha">pras<unclear>ā</unclear></hi>
                    <lb n="6" break="no"/><hi rend="grantha">da</hi>ñ cetaruḷiya tiru-muka-p-paṭ<supplied reason="lost">i</supplied> y-aruḷi-c ceyal nallūr-uṭaiyār nalla ṉāyaṉār kōyil tāṉattāṟ-ā
                    <lb n="7" break="no"/><unclear>na</unclear> nammuṭaiya pērāl patiṉañc-āvatu mutal kaṭṭiṉa cantikkum tai-t-tiru-ṉāḷukkum Uṭal āka Iṉṉāya 
                    <lb n="8" break="no"/>ṉār tiru-ṉāmattu-k-kāṇi tēvatānam-āṉa nallūr naṉcey-puṉceyum kācāya vaṟkamum Uḷḷiṭṭa A
                    <lb n="9" break="no"/>ṉaittu vaṟkamum mutal aṭaṅka Iṟai-y-ili-y-āka patiṉ aiñcāvatu mutal tantōm
                </p>
                <p>
                    Ippaṭikku
                    <lb n="10"/>Ivv-ōlai muṭipāṭ’ āka-k koṇṭu kalliluñ cempilum veṭṭi-k koḷka 
                </p>
                <p>
                    Ivai cuntara-pāṇṭi
                    <lb n="11" break="no"/><unclear>ya</unclear>-viḻupparaiyaṉ Eḻuttu
                </p>
                <p>
                    Itu paṉ<hi rend="grantha">māheśvara-rakṣai</hi> <g ref="sym:tam-pillaiyarCuli" type="punctuation">.</g>
                </p>
